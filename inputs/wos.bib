@inproceedings{ WOS:000835706300025,
Author = {Paik, Incheon},
Book-Group-Author = {IEEE},
Title = {Semantic Repository for Automatic Deep Learning Generation},
Booktitle = {16TH IEEE INTERNATIONAL CONFERENCE ON SEMANTIC COMPUTING (ICSC 2022)},
Series = {IEEE International Conference on Semantic Computing},
Year = {2022},
Pages = {167-170},
Note = {16th IEEE International Conference on Semantic Computing (ICSC), ELECTR
   NETWORK, JAN 26-28, 2022},
Organization = {IEEE; IEEE Comp Soc},
Abstract = {The automation of DL model has focused on model optimization, wholistic
   DL generation is an unexplored field. To address the issues, we propose
   a novel framework and method that enables DL architectures and data,
   developed by artificial-intelligence experts, to be shared by business
   developers who are not such specialized experts. In this paper, we focus
   on two issues: the generation of data for DL and DL architecture
   generation. The overall framework considers adaptability towards
   frequent updates and new architectural approaches by separating the
   system knowledge from the generation procedure for the DL architecture.
   The design strategy involves the creation of an ontology for the DL
   generation process and the construction of a rule for generating the DL
   architecture and its data. We demonstrate the entire DL generation
   workflow using an example scenario, with a user request forming the
   requirement. A prototype implementation to show working of inference on
   the ontology for DL generation is illustrated, and an evaluation of our
   repository comparing with the existing system is provided.},
