@article{ WOS:001466418200001,
Author = {Vijayakumar, D. and Srinivasagan, K. G. and Vivekrabinson, K.},
Title = {Enhancing cloud storage security through blockchain-enabled data
   deduplication and auditing with a fair payment},
Journal = {PEER-TO-PEER NETWORKING AND APPLICATIONS},
Year = {2025},
Volume = {18},
Number = {3},
Month = {APR 14},
Abstract = {Security and performance are currently the two main issues due to the
   increased use of cloud storage. These issues can be prevented by solid
   countermeasures like data deduplication and data auditing techniques.
   Numerous studies on deduplication using data auditing techniques have
   been conducted. However, issues including high cost, dependence on
   trusted external parties, and recurrent audits of data shared by
   multiple tenants still need to be resolved. In this research, a data
   deduplication technique with blockchain-based data integrity validation
   is suggested to promise the consistency of the information in the cloud.
   In this study, data deduplication is performed on the client side,
   minimizing the amount of data that must be outsourced, computational
   time, and the bandwidth necessary to transmit the information between
   the user and storage provider. Here, the blockchain system records the
   data that was outsourced, and these immutable records may be used for
   auditing to assure trustworthiness and integrity. The system also
   supports the automatic punishment of fraudulent users who attempt to
   interfere with the system by establishing a smart contract. Our
   experimental findings further show that the suggested approach
   outperforms existing approaches by 38\% in computation overhead and 76\%
   in auditing overhead.},
