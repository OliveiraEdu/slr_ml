@article{ WOS:001554356600012,
Author = {Peng, Xueqi and Shen, Wenting and Gao, Yuan and Su, Ye},
Title = {Blockchain-based secure deduplication and cloud storage auditing with
   fair arbitration and privacy protection},
Journal = {CLUSTER COMPUTING-THE JOURNAL OF NETWORKS SOFTWARE TOOLS AND
   APPLICATIONS},
Year = {2025},
Volume = {28},
Number = {8},
Month = {AUG 19},
Abstract = {Cloud data auditing with data deduplication not only allows the verifier
   to check the integrity of data stored in the cloud server (CS), but also
   improves cloud storage efficiency. However, most of the existing cloud
   data auditing schemes with data deduplication are not only vulnerable to
   duplicate faking attack and brute force dictionary attack, but also rely
   on a trusted third-party auditor (TPA) to complete data integrity
   auditing. Moreover, these schemes require significant communication
   overhead to perform interactive auditing and proofs of ownership (PoW)
   tasks. To address the above issues, we propose a blockchain-based secure
   deduplication and cloud storage auditing scheme with fair arbitration
   and privacy protection. In our scheme, data privacy can be protected
   under brute force dictionary attack by introducing a file index
   generation method. The designed file index can help the CS to check the
   consistency between the file index and the ciphertext to resist
   duplicate faking attack. We propose a fair arbitration mechanism and a
   non-interactive mechanism based on blockchain. Using the above
   mechanisms, the malicious entity can be identified based on the
   information recorded on the blockchain after service disputes. The
   communication overhead of auditing and PoW can be reduced. The security
   and efficiency of the proposed scheme are substantiated through security
   analysis and performance evaluation.},
