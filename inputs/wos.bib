@inproceedings{ WOS:001162031400004,
Author = {Bang, N. H. and Khoa, T. D. and Triet, M. N. and Khanh, V. H. and Khiem,
   H. G. and Bao, Q. T. and Phuc, N. T. and Hieu, M. D. and Loc, V. C. P.
   and Quy, T. L. and Anh, N. T. and Hien, Q. N. and Bang, L. K. and Trong,
   D. P. N. and Ngan, N. T. K. and Son, H. and Luong, H. H.},
Editor = {Haghighi, PD and Khalil, I and Kotsis, G and Sanjaya, ERNA},
Title = {Blockchain-Enhanced IoHT: A Patient-Centric Internet of Healthcare
   Things Platform with Smart Contract-Driven Data Management},
