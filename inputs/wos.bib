Title = {Blockchain-based Built Environment Data Management for Modular
   Construction},
Booktitle = {2024 IEEE INTERNATIONAL SMART CITIES CONFERENCE, ISC2},
Series = {IEEE International Smart Cities Conference},
Year = {2024},
Note = {2024 International Smart Cities Conference-ISC2-Annual, Pattaya,
   THAILAND, OCT 29-NOV 01, 2024},
Abstract = {As a modern construction method, Modular Construction (MC) could solve
   challenges such as project delays, inefficiencies, and environmental
   pollution in the construction and real estate industry. However, the use
   of new methods introduces novel challenges of their own. Logistical
   aspects of modular construction such as proof of materials origin and
   verification of properties, can be addressed through the use of
   innovations such as the DPP. However, to meet the DPP specifications as
   e.g. proposed by the European Union, the construction industry needs to
   expedite its digital transformation. This paper describes a full
   lifecycle workflow of a modern MC project based on BIM, IoT, and
   Blockchain, that could facilitate leveraging innovations such as the
   DPP. Additionally, it contributes to the more efficient implementation
   of MC as a digitalised construction method.},
