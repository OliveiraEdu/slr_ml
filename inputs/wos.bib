@article{ WOS:001427662300008,
Author = {Kalyuzhnaya, T. A. and Pleshakova, M. A.},
Title = {Bibliometric Analysis of the Topic ``Research Data Repository{''}},
Journal = {SCIENTIFIC AND TECHNICAL INFORMATION PROCESSING},
Year = {2024},
Volume = {51},
Number = {4},
Pages = {340-350},
Month = {DEC},
Abstract = {The structure of the scientific landscape in the field of creation and
   maintenance of research data repositories (RDRs) in the world library
   practice is considered. Based on the document flow of the Dimensions
   database using Bibliometrix 4.0 for R with descriptive and network
   analysis of the conceptual structure, the context of research in the
   field of RDRs from 2007 to early June 2024 is reproduced. Exponential
   growth of publications was discovered, leaders in the study of RDRs were
   established (Germany and the United States). The maximum citation of
   works was recorded in 2016, which is connected with the release of the
   first official edition of the FAIR Principles, which received the
   highest citation index among publications on the topic during the period
   under study. The topic of RDRs as a field of research has emerged
   recently and in the last decade has been characterized by a significant
   increase in publications in six main areas: research data, data
   exchange, research results, digital libraries, research communities, and
   article descriptions. The connection of the thematic area with library
   and information activities is determined by the presence of clusters
   ``library staff,{''} ``library system,{''} and ``public libraries{''}
   and the presence of these topics in clusters ``research data,{''}
   ``institutional repositories,{''} ``digital curation.{''}},
