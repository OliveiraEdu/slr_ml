@inproceedings{ WOS:001304470300022,
Author = {Prasad, Sanjana and RajendraPrasad, Deepashree},
Editor = {Kumar, S and Balachandran, K and Kim, JH and Bansal, JC},
Title = {Comparative Analysis of Blockchain Technology in Healthcare Data
   Management},
Booktitle = {FOURTH CONGRESS ON INTELLIGENT SYSTEMS, VOL 3, CIS 2023},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
