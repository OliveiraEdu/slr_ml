Title = {Blockchain-Based Fair Certified Notifications},
Booktitle = {DATA PRIVACY MANAGEMENT, CRYPTOCURRENCIES AND BLOCKCHAIN TECHNOLOGY},
Series = {Lecture Notes in Computer Science},
Year = {2018},
Volume = {11025},
