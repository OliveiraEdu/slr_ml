   Ji, Yusheng, Natl Inst Informat, Informat Syst Architecture Res Div, Tokyo 1018430, Japan.
   Cao, Yangjie, Zhengzhou Univ, Sch Software, Zhengzhou 450000, Henan, Peoples R China.},
DOI = {10.1109/JIOT.2021.3102236},
ISSN = {2327-4662},
