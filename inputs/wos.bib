@inproceedings{ WOS:000273268500136,
Author = {Belaid, Nabil and Ait-Ameur, Yamine and Rainaud, Jean-Francois},
Editor = {Damiani, E and Zhang, J and Chang, R},
Title = {A semantic repository for geological modeling workflows},
Booktitle = {2009 IEEE INTERNATIONAL CONFERENCE ON WEB SERVICES, VOLS 1 AND 2},
Year = {2009},
Pages = {1030+},
Note = {IEEE International Conference on Web Services (ICWS 2009), Los Angeles,
   CA, JUL 06-10, 2009},
Organization = {IEEE Comp Soc TCSC},
Abstract = {Nowadays, many engineering studies are conducted to securely exploit
   depleted Oil Fields for CO2 Storage. These studies follow complex
   workflows of data processing services described by geologists. If no
   explicit semantics is applied to describe these workflows, it is not
   possible to share them between geologists by reusing existing ones or
   for composing new ones. The focus of our work is to make the semantics
   explicit in order to facilitate the geologists daily work. In this
   article, we first explain how geologists operate today. Then, we enrich
   such workflows with semantic indexes through ontology based
   characterizations.},
