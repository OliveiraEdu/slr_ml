Volume = {7},
Number = {1},
Pages = {19-29},
Month = {MAR},
Abstract = {We discuss verification of nonblocking of a supervised discrete event
   system when control is exercised in a decentralized fashion by several
   local supervisors.  In a decentralized configuration, in general,
   nonblocking of all local supervisors does not guarantee nonblocking of
   the overall system.  We will provide some sufficient conditions that
   guarantee nonblocking of the overall system.},
