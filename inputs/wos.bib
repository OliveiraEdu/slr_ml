@inproceedings{ WOS:000477747000026,
Author = {Rasin, Alexander and Malik, Tanu and Wagner, James and Kim, Caleb},
Editor = {Belhajjame, K and Gehani, A and Alper, P},
Title = {Where Provenance in Database Storage},
Booktitle = {PROVENANCE AND ANNOTATION OF DATA AND PROCESSES, IPAW 2018},
