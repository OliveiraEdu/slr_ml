Title = {DECENTRALIZED REPLICATION STRATEGIES FOR P2P BASED SCIENTIFIC DATA GRID},
Booktitle = {INTERNATIONAL SYMPOSIUM OF INFORMATION TECHNOLOGY 2008, VOLS 1-4,
   PROCEEDINGS: COGNITIVE INFORMATICS: BRIDGING NATURAL AND ARTIFICIAL
   KNOWLEDGE},
