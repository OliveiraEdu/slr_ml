@inproceedings{ WOS:000520130100046,
Author = {Jamal, Arshad and Helmi, Rabab Alayham Abbas and Syahirah, Ampuan Siti
   Nurin and Fatima, Mariam-Aisha},
Book-Group-Author = {IEEE},
Title = {Blockchain-Based Identity Verification System},
Booktitle = {2019 IEEE 9TH INTERNATIONAL CONFERENCE ON SYSTEM ENGINEERING AND
   TECHNOLOGY (ICSET)},
Series = {International Conference on System Engineering and Technology},
Year = {2019},
