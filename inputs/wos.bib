@inproceedings{ WOS:000432425300048,
Author = {Kalemi, Edlira and Koo, Linsey and Cecelja, Franjo},
Editor = {Espuna, A and Graells, M and Puigjaner, L},
Title = {A Semantic Repository for Model Integration in Biorefining},
Booktitle = {27TH EUROPEAN SYMPOSIUM ON COMPUTER AIDED PROCESS ENGINEERING, PT C},
Series = {Computer Aided Chemical Engineering},
Year = {2017},
Volume = {40C},
Pages = {2323-2328},
Note = {27th European Symposium on Computer-Aided Process Engineering (ESCAPE),
   Barcelona, SPAIN, OCT 01-05, 2017},
Abstract = {Solving complex problems in biorefining associated with the process or
   unit design, process synthesis and analysis, or pure understanding the
   potential, heavily rely on modelling and simulation, the activity which
   remains implicit to the engineers who built them and hence limited to
   their use. The importance of model reusability, therefore, has been
   realised and the major contribution towards their interoperability and
   hence integration was provided by computer aided process engineering
   (CAPE) community (Belaud \& Pons 2002). We argue that existence of a
   flexible, readily available and simple to use model repository is a
   precondition for model sharing and reusing and hence for model
   integration towards solving particular problems. This paper proposes a
   semantic repository which enables model registration, model discovery
   and concomitantly model integration. The functionality of repository is
   fully controlled by a biorefining domain ontology implemented using
   Ontology Web Language (OWL) and published on semantic web. The
   functionality of the repository has been tested using several
   biorefining related scenarios.},
