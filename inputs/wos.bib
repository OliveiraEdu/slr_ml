@inproceedings{ WOS:000449788200034,
Author = {Voronin, Viacheslav and Semenishchev, Evgenii and Zelensky, Aleksandr
   and Svirin, Iliya and Alepko, Andrey},
Book-Group-Author = {IEEE},
Title = {Video content verification using blockchain technology},
Booktitle = {2018 IEEE INTERNATIONAL CONFERENCE ON SMART CLOUD (SMARTCLOUD)},
Year = {2018},
Pages = {208-212},
Note = {3rd IEEE International Conference on Smart Cloud (SmartCloud), Columbia
   Univ, New York, NY, SEP 21-23, 2018},
Organization = {IEEE; IEEE Comp Soc; IEEE TCSC; IEEE STC Smart Comp; Natl Sci Fdn;
   Beijing Inst Technol; Longxiang High Tech Grp Inc; N Amer Chinese
   Talents Assoc},
Abstract = {In distributed high-performance systems that allow processing large data
   sets, the important task is the analysis and verification of the video
   data. The problem of confirming data is relevant for many areas. The
   need for this arises when fixing offences, banking, remote management,
   confirmation of actions, etc. In this paper, we describe an approach to
   verifying video received by a mobile device like mobile phone, tablet or
   PC, equipped with a camera and controlled by the operating system
   (Windows, Android or iOS). The proposed algorithm uses the procedure of
   entering the Swype code using the movement mobile camera. To improving
   the accuracy, we use additional information from different mobile
   sensors like accelerometer, gyro, barometer, and GPS. In the process of
   data verification, video transmission to the server is not perform what
   ensures the privacy of the captured video data. The server and mobile
   device stores data about the file size, the date of its recording, the
   time, the data device and its position.},
