@article{ WOS:000580507800001,
Author = {Kim, Suah and Sachnev, Vasily and Kim, Hyoung Joong},
Title = {Rentable CDN Using Blockchain and Proof of Provenance},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2020},
Volume = {10},
Number = {18},
Month = {SEP},
Abstract = {Featured Application Rentable content delivery network with proof of
   provenance provides s p2p based content distribution network
   infrastructure that supports content control, is less vulnerable to
   variety of collusion attacks, and provides faster content transfer
   speed. Building a rentable content delivery network (CDN), a p2p based
   CDN that supports content control and is composed of hardware rented
   from consumers, requires significant trust between the renters and
   consumers. The proposed method solves this using a Blockchain to provide
   transparency in running the network, and proof of provenance, a
   verifiable proof origin of the content that is used to determine who can
   get paid for their services to discourage malicious activities.},
