Note = {International Conference on Cyber Security Intelligence and Analytics
   (CSIA), Shenyang, PEOPLES R CHINA, FEB 21-22, 2019},
Abstract = {Hive's data is stored in HDFS, and most of the queries are done by
   MapReduce, which is a large-scale data mechanism that can be stored,
   queried and analyzed in Hadoop. Hive can convert SQL statements into
   MapReduce tasks, which has the advantages of low learning cost and easy
   MapReduce statistics through SQL like statements. Most queries in Hive
   are executed through the MapReduce provided by Hadoop. This paper
   introduces the metadata storage and query of Hive based on Hadoop
   distributed platform.},
