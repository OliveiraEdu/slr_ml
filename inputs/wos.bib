@inproceedings{ WOS:001558365100010,
Author = {Bertrand, Nathalie and Gramoli, Vincent and Konnov, Igor and Lazic,
   Marijana and Tholoniat, Pierre and Widder, Josef},
Editor = {Scheideler, C},
Title = {Holistic Verification of Blockchain Consensus},
