@article{ WOS:001579275600001,
Author = {Zibani, Patiswa and Rajkoomar, Mogiveny and Naicker, Nalen and
   Marimuthu, Ferina},
Title = {Navigating research data management challenges in an academic landscape:
   a framework for a university of technology research repository context},
Journal = {DIGITAL LIBRARY PERSPECTIVES},
Year = {2025},
Month = {2025 SEP 30},
Abstract = {PurposeThis study aims to explore research data management within a
   faculty setting to facilitate researchers by designing a specialized
   research data repository platform tailored for the University of
   Technology. In contemporary academia, the research community
   acknowledges the pivotal role of research data in propelling scientific
   advancement. The study examined Research Data Management (RDM) practices
   from the perspectives of master's and doctoral students and research
   supervisors in the Faculty of Accounting \& Informatics (FAI) at the
   Durban University of Technology (DUT) to comprehend existing challenges
   and opportunities surrounding RDM within this
   domain.Design/methodology/approachThis study followed an explanatory
   sequential mixed-method research approach, employing online surveys and
   interviews. The online survey included 95 postgraduate students from FAI
   enrolled in masters and doctoral programs between 2015 and 2020. The
   postgraduate students were identified for their active roles in
   contributing to research data. In addition, interviews were conducted
   using a qualitative data collection method involving ten supervisors
   responsible for guiding master's and doctoral students within the FAI at
   DUT.FindingsThe study findings highlighted that research data management
   was primarily treated as an individual responsibility. The primary
   reason for the difficulties was the faculty's lack of investment in
   research data management. This was evident in practices like relying on
   email, external hard drives and personal laptops, underscoring the
   absence of centralized systems for effective research data management
   within the faculty. However, it is important to note that participants
   recognized the advantages of proper research data management, including
   driving scientific advancements, improving data reusability and
   simplifying data access for other users. In addition, the research
   findings revealed that the absence of platforms facilitating data
   sharing and reuse constituted a significant obstacle preventing most
   researchers from engaging in these practices. Nonetheless, researchers
   strongly desired to share their data without imposing any
   restrictions.Originality/valueThis study introduces an innovative
   framework that guides the planning and implementation of the Faculty
   Research Data Repository Platform's design. Grounded in a comprehensive
   examination of research data management practices within the faculty, a
   thorough literature review and recommendations drawn from the research
   findings, this framework contributes to establishing a structured
   platform for managing and sharing research data within faculties and
   other academic institutions.},
