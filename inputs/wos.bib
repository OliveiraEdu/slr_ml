Pages = {43+},
Note = {2006 USENIX Annual Technical Conference, Boston, MA, MAY 30-JUN 03, 2006},
Organization = {USENIX; Google; IBM; VMware; ACM Queue; Addison Wesley; Professional
   Prentice; Hall Professional; GRIDtoday; HPCwire; IEEE Secur \& Privacy;
   ITtoolbox; Linux Journal; No Starch Press; OSTG; SNIA; Storage
   Networking Org; Syst Adm; UserFriendly Org},
Abstract = {A Provenance-Aware Storage System (PASS) is a storage system that
   automatically collects and maintains provenance or lineage, the complete
   history or ancestry of an item. We discuss the advantages of treating
   provenance as meta-data collected and maintained by the storage system,
   rather than as manual annotations stored in a separately administered
   database. We describe a PASS implementation, discussing the challenges
   it presents, performance cost it incurs, and the new functionality it
   enables. We show that with reasonable overhead, we can provide useful
   functionality not available in today's file systems or provenance
   management systems.},
