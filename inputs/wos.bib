@inproceedings{ WOS:000555294400015,
Author = {Skluzacek, Tyler J.},
Book-Group-Author = {Assoc Comp Machinery},
Title = {Dredging a Data Lake: Decentralized Metadata Extraction},
Booktitle = {MIDDLEWARE'19: PROCEEDINGS OF THE 2019 20TH INTERNATIONAL MIDDLEWARE
   CONFERENCE DOCTORAL SYMPOSIUM},
Year = {2019},
Pages = {51-53},
