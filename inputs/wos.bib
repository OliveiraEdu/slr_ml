@inproceedings{ WOS:000691552500080,
Author = {Tang, Wenyi and Chenli, Changhao and Jung, Taeho},
Book-Group-Author = {IEEE},
Title = {Prv2chain: Storage of Tree-structured Provenance Records in
   Blockchain with Linkage Privacy},
Booktitle = {2021 IEEE INTERNATIONAL CONFERENCE ON BLOCKCHAIN AND CRYPTOCURRENCY
   (ICBC)},
Year = {2021},
Note = {3rd IEEE International Conference on Blockchain and Cryptocurrency (IEEE
   ICBC), ELECTR NETWORK, MAY 03-06, 2021},
Organization = {IEEE; IEEE Commun Soc; IBM; CSIRO, Data61},
Abstract = {Storing provenance records on blockchain has the benefit of guaranteed
   integrity, however keeping the records private against the peers
   maintaining the blockchain is challenging especially when the records
   have linkages among them. This paper studies the problem of storing
   tree-structured provenance records with linkages in blockchain while
   keeping the linkages private. We present Prv(2)chain, a framework that
   allows users to privately store their linked provenance records while
   protecting the records and their linkages. Users are also allowed to
   perform on-chain tree traversal efficiently. These are enabled by our
   novel record ID generation algorithms. Our experiments indicate the
   extra overhead incurred by Prv(2)chain is little enough for practical
   deployment.},
