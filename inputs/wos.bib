@inproceedings{ WOS:001054524500003,
Author = {Knodel, Oliver and Voigt, Martin and Ufer, Robert and Pape, David and
   Lokamani, Mani and Mueller, Stefan E. and Gruber, Thomas and Juckeland,
   Guido},
Book-Group-Author = {ACM},
Title = {HELIPORT: A Portable Platform for FAIR \{Workflow | Metadata |
   Scientific Project Lifecycle\} Management and Everything},
Booktitle = {PROCEEDINGS OF THE 4TH INTERNATIONAL WORKSHOP ON PRACTICAL REPRODUCIBLE
   EVALUATION OF COMPUTER SYSTEMS, P-RECS 2021},
Year = {2021},
