Note = {IEEE 19th International Conference on Information Reuse and Integration
   for Data Science (IRI), Salt Lake City, UT, JUL 07-08, 2018},
Organization = {IEEE Comp Soc; Soc Information Reuse \& Integration},
Abstract = {Managing ever-growing content from heterogeneous data sources is a
   significant challenge in enterprise environments. Many data analysis
   tools work in isolation to capture various statistical, quality, and
   provenance information within the enterprise. Yielding meaningful and
   consistent information from a landscape of different vendor tools
   requires a holistic and transparent view over all existing extracted
   metadata. In this paper, we present our Universal Metadata Repository
   (UMR) applied to three in-flight use cases which combine the power of a
   technical and business view using knowledge graphs for: searching,
   inferencing, traceability, administration, enforcing accessibility
   standards, and providing consistent organizational architecture.},
