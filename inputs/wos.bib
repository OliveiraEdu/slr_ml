Title = {A Bibliometric Analysis and Systematic Review of a Blockchain-Based
   Chain of Custody for Digital Evidence},
Booktitle = {BIG DATA TECHNOLOGIES AND APPLICATIONS, EAI INTERNATIONAL CONFERENCE,
   BDTA 2023},
Series = {Lecture Notes of the Institute for Computer Sciences Social Informatics
   and Telecommunications Engineering},
