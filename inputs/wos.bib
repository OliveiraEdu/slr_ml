Organization = {Association for Computing Machinery},
Abstract = {The Nebraska Research Data Storage (NRDStor) service, provided by the
   University of Nebraska, aims to simplify and accelerate researchers'
   access to computing resources, including campus computing clusters.
   Researchers can access NRDStor through two convenient methods: directly
   through the file system mounted on compute worker nodes or utilizing the
   SMB protocol from any campus networked computer. Furthermore, NRDStor
   enhances the ease of sharing research data and results through
   integration with the Open Science Data Federation (OSDF) and Globus.},
