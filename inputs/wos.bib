Title = {Fortifying Decentralized Governance: Introducing Decentralized
   Autonomous Verification (DAVe) for Decentralized Autonomous Organization
   (DAOs) Security},
Booktitle = {28TH INTERNATIONAL CONFERENCE ON INTELLIGENT ENGINEERING SYSTEMS, INES
   2024},
Series = {IEEE International Conference on Intelligent Engineering Systems},
Year = {2024},
Pages = {49-53},
