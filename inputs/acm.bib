@inproceedings{10.1145/3512676.3512678,
author = {Toyoda, Kentaroh and Lim Kim Moh, Justin and Hsu Hlaing Mon, Nang and Soo, Alvin},
title = {Design and Implementation of Blockchain-enabled Immutable and Interoperable Data Management System for Enterprise Systems},
year = {2022},
isbn = {9781450387422},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
