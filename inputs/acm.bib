@inproceedings{10.1145/3571884.3604403,
author = {de Wit, Jan and Braggaar, Anouck},
title = {Tilbot: A Visual Design Platform to Facilitate Open Science Research into Conversational User Interfaces},
year = {2023},
isbn = {9798400700149},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
